# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo
.expo/
.expo-shared/

# ...except electron-builder's hook scripts/entitlements, which are source,
# not output — "build/" above is a blanket rule that would otherwise catch it.
!packages/desktop/build/
!packages/desktop/build/**

# Expo Continuous Native Generation — android/ and ios/ are regenerated by
# `expo prebuild --clean` on every local build; native tweaks live in
# scripts/patch-android-prebuild.mjs, not in the generated tree.
packages/app/android/
packages/app/ios/

# Logs
*.log
.npm
.eslintcache

# Environment files
.env
.env.local
.env.*.local

# OS noise
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp

# Test coverage
coverage/

# Claude Code local settings
.claude/settings.local.json
