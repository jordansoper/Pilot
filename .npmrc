# Expo / React Native native builds shell out to `node --print
# require.resolve(...)` from the generated android/ project without passing
# `paths`, which fails under pnpm's default isolated node_modules (transitive
# deps like @react-native/gradle-plugin aren't resolvable there). A hoisted
# (flat) node_modules is what Expo documents for pnpm monorepos and lets those
# resolutions succeed. See TROUBLESHOOTING §5.
node-linker=hoisted
