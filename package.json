{
  "name": "pilot",
  "version": "0.0.0",
  "private": true,
  "description": "Remote CLI connector — pair a phone with your dev machines to launch AI CLIs from anywhere. See PROJECT_PLAN.md.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty-perms.mjs",
    "build": "pnpm -r --topological build",
    "dev:cli": "pnpm --filter @pilot/shared build && pnpm --filter @pilot/cli dev",
    "dev:app": "pnpm --filter @pilot/shared build && pnpm --filter @pilot/app start",
    "typecheck": "pnpm -r --topological build && pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "test": "pnpm -r --topological build && pnpm -r test",
    "clean": "pnpm -r clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.5",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3",
    "typescript": "5.6.3",
    "typescript-eslint": "^8.10.0",
    "vitest": "^2.1.3"
  }
}
