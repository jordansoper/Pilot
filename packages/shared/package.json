{
  "name": "@pilot/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Zod schemas, types, and constants shared by pilot-cli and pilot-app.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./src": "./src/index.ts"
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -b",
    "prepare": "tsc -b",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "5.6.3",
    "vitest": "^2.1.3"
  }
}
