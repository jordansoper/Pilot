{
  "name": "@pilot/cli",
  "version": "0.0.0",
  "private": true,
  "description": "pilot-cli — daemon that runs on the dev machine. Phase 1: QR pairing + WS /ws/pty (bash via node-pty) over Tailscale.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "pilot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/index.ts",
    "start:dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "smoke": "tsx src/__tests__/smoke.ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@pilot/shared": "workspace:*",
    "node-pty": "^1.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.5.12",
    "tsx": "^4.19.1",
    "typescript": "5.6.3",
    "vitest": "^2.1.3"
  }
}
