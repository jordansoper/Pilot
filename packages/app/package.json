{
  "name": "@pilot/app",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "echo 'see build:android:preview / build:android:production / build:android:local:*'",
    "clean": "echo 'nothing to clean yet'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "prebuild:android": "expo prebuild --platform android --clean",
    "build:android:preview": "eas build --platform android --profile preview --non-interactive",
    "build:android:production": "eas build --platform android --profile production --non-interactive",
    "patch:android": "node ../../scripts/patch-android-prebuild.mjs",
    "build:android:local:debug": "pnpm prebuild:android && pnpm patch:android && cd android && ./gradlew assembleDebug",
    "build:android:local:release": "pnpm prebuild:android && pnpm patch:android && cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@pilot/shared": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~51.0.0",
    "expo-camera": "~15.0.2",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-webview": "13.8.6"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "typescript": "5.6.3",
    "vitest": "^2.1.3"
  }
}
